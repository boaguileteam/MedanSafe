<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0A0E1A"
        android:paddingVertical="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="20dp"
            android:background="@drawable/cr12bffffff0d"
            android:padding="13dp"
            android:src="@drawable/ic_back1"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="Kebijakan Privasi"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintTop_toTopOf="@id/btnBack" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/btnUnderstood"
        app:layout_constraintTop_toBottomOf="@id/clHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="Informasi yang Kami Kumpulkan"
                android:textColor="#1E293B"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="MedanSafe mengumpulkan data lokasi GPS secara real-time untuk menampilkan peta dan marker insiden di sekitar kamu. Data lokasi hanya digunakan selama sesi aktif dan tidak disimpan di server tanpa izin kamu."
                android:textColor="#64748B"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="Laporan Insiden"
                android:textColor="#1E293B"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="Saat kamu mengirim laporan insiden, data yang disimpan meliputi: koordinat GPS, kategori insiden, deskripsi (opsional), dan foto (opsional). Laporan dapat ditampilkan secara anonim jika kamu mengaktifkan pengaturan Sembunyikan Nama."
                android:textColor="#64748B"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="Fitur Panic Mode SOS"
                android:textColor="#1E293B"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="Saat tombol SOS ditekan, MedanSafe mengirimkan pesan SMS berisi koordinat GPS kamu ke kontak darurat yang telah kamu simpan. Nomor telepon kontak darurat disimpan hanya di perangkat kamu dan tidak diunggah ke server."
                android:textColor="#64748B"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="Keamanan Data"
                android:textColor="#1E293B"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="Seluruh data yang dikirim ke server menggunakan enkripsi Firebase Security Rules. Akun kamu dilindungi oleh Firebase Authentication. Kami tidak menjual atau membagikan data pribadi kamu kepada pihak ketiga."
                android:textColor="#64748B"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="Hak Pengguna"
                android:textColor="#1E293B"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="Kamu dapat menghapus akun dan seluruh data kamu kapan saja melalui menu Profil > Hapus Akun. Untuk pertanyaan terkait privasi, hubungi kami di medansafe.support@gmail.com"
                android:textColor="#64748B"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="Terakhir diperbarui: April 2026\nDikembangkan oleh Tim BoaGuile untuk MCC 2026 · UMSU Medan"
                android:textColor="#94A3B8"
                android:textSize="11sp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnUnderstood"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_margin="20dp"
        android:background="@drawable/bg_button_rounded_red"
        android:fontFamily="@font/plus_jakarta_sans"
        android:text="Saya Mengerti"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>