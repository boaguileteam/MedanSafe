<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <!-- Dark Header Area -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_header"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="#0A0E1A"
        app:layout_constraintTop_toTopOf="parent">

        <!-- DECORATIVE CIRCLE -->
        <View
            android:id="@+id/view_decorative_circle"
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:layout_marginTop="-45dp"
            android:layout_marginEnd="-45dp"
            android:background="@drawable/cr60bc0392b12"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.cardview.widget.CardView
            android:id="@+id/btn_back_container"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#2D2D44"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:src="@drawable/ic_back1"
                app:tint="#FFFFFF"
                android:contentDescription="@string/desc_back_icon" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="Peta"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/btn_back_container"
            app:layout_constraintStart_toEndOf="@id/btn_back_container"
            app:layout_constraintTop_toTopOf="@id/btn_back_container" />

        <TextView
            android:id="@+id/tv_title_main"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="Skor Keamanan Rute"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_back_container" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable content area -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/ll_bottom_buttons"
        app:layout_constraintTop_toBottomOf="@id/cl_header"
        android:layout_marginTop="-50dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <!-- Route Information Card (CLICKABLE TO CHANGE) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_route_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">
                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_google_circle"
                            android:backgroundTint="#4285F4" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lokasi Saat Ini"
                                android:textColor="#1E293B"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/tv_risk_start_addr"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Jl. Gatot Subroto"
                                android:textColor="#64748B"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="4.5dp"
                        android:background="#E2E8F0" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">
                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_google_circle"
                            android:backgroundTint="#EF4444" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tv_risk_dest_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sun Plaza Medan"
                                android:textColor="#1E293B"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/tv_risk_route_info"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3.2 km • Est. 12 menit"
                                android:textColor="#64748B"
                                android:textSize="12sp" />
                        </LinearLayout>
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_search"
                            app:tint="#CBD5E1" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Score Display -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_score_outer_glow"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="80dp"
                app:cardElevation="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cv_route_details">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tv_risk_score_display"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="60"
                        android:textColor="#F59E0B"
                        android:textSize="36sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="/100"
                        android:textColor="#94A3B8"
                        android:textSize="14sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tv_risk_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_status_badge"
                android:backgroundTint="#FEF3C7"
                android:fontFamily="@font/plus_jakarta_sans"
                android:paddingHorizontal="24dp"
                android:paddingVertical="8dp"
                android:text="WASPADA"
                android:textColor="#D97706"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cv_score_outer_glow" />

            <!-- New Route Mode Tag -->
            <TextView
                android:id="@+id/tv_route_mode_tag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_risk_label" />

            <!-- Risk Factors Section -->
            <TextView
                android:id="@+id/tv_factors_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:letterSpacing="0.1"
                android:text="FAKTOR RISIKO"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_route_mode_tag" />

            <LinearLayout
                android:id="@+id/ll_risk_factors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/tv_factors_title">

                <!-- Factor 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <androidx.cardview.widget.CardView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        app:cardBackgroundColor="#FEE2E2"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp">
                        <TextView
                            android:id="@+id/tv_factor_1_emoji"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="⚠️"
                            android:textSize="16sp" />
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:id="@+id/tv_factor_1_desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="4 laporan insiden (30 hari)"
                        android:textColor="#1E293B"
                        android:textSize="13sp" />
                    <ProgressBar
                        android:id="@+id/pb_factor_1"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="60dp"
                        android:layout_height="4dp"
                        android:progress="70"
                        android:progressTint="#F59E0B" />
                </LinearLayout>

                <!-- Factor 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <androidx.cardview.widget.CardView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        app:cardBackgroundColor="#FEE2E2"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp">
                        <TextView
                            android:id="@+id/tv_factor_2_emoji"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="🌙"
                            android:textSize="16sp" />
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:id="@+id/tv_factor_2_desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="Malam hari (22:00 WIB)"
                        android:textColor="#1E293B"
                        android:textSize="13sp" />
                    <ProgressBar
                        android:id="@+id/pb_factor_2"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="60dp"
                        android:layout_height="4dp"
                        android:progress="90"
                        android:progressTint="#EF4444" />
                </LinearLayout>

                <!-- Factor 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <androidx.cardview.widget.CardView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        app:cardBackgroundColor="#DCFCE7"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp">
                        <TextView
                            android:id="@+id/tv_factor_3_emoji"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="💡"
                            android:textSize="16sp" />
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:id="@+id/tv_factor_3_desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="Penerangan cukup"
                        android:textColor="#1E293B"
                        android:textSize="13sp" />
                    <ProgressBar
                        android:id="@+id/pb_factor_3"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="60dp"
                        android:layout_height="4dp"
                        android:progress="30"
                        android:progressTint="#10B981" />
                </LinearLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Buttons Area -->
    <LinearLayout
        android:id="@+id/ll_bottom_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cv_btn_glow_container"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:cardBackgroundColor="#10B981"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_risk_find_safer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="Cari Rute Lebih Aman"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_risk_keep_current"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_red_outline"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="Tetap Gunakan Rute Ini"
            android:textAllCaps="false"
            android:textColor="#EF4444"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>