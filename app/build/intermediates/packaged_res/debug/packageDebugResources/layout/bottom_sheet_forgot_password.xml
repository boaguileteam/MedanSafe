<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="32dp">

        <View
            android:layout_width="48dp"
            android:layout_height="4dp"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"
            android:background="#E2E8F0"
            android:alpha="0.8"/>

        <!-- Header Title -->
        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="Lupa\nPassword?"
            android:textColor="#1E293B"
            android:textSize="24sp"
            android:textStyle="bold"
            android:lineSpacingExtra="-2dp"
            android:layout_marginBottom="8dp"/>

        <!-- State 1: Select Method & Input -->
        <LinearLayout
            android:id="@+id/stateInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="Pilih metode verifikasi untuk reset kata sandi"
                android:textColor="#64748B"
                android:textSize="14sp" />

            <!-- Opsi Via Email (Red Border when selected) -->
            <LinearLayout
                android:id="@+id/cardEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/sc0392bsw1cr14"
                android:orientation="vertical"
                android:padding="20dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_icon_rounded_light_red" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="-36dp"
                        android:src="@drawable/ic_email"
                        app:tint="#C0392B"
                        android:contentDescription="@string/label_email" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="26dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:text="Email Terdaftar"
                            android:textColor="#1E293B"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:text="Terima tautan verifikasi otomatis"
                            android:textColor="#94A3B8"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/container_input_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="MASUKKAN ALAMAT EMAIL"
                        android:textColor="#475569"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"/>

                    <EditText
                        android:id="@+id/et_reset_email"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/se2e8f0sw1cr14bf8fafc"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:inputType="textEmailAddress"
                        android:paddingHorizontal="16dp"
                        android:textColor="#1E293B"
                        android:textSize="14sp"
                        android:hint="@string/hint_email"
                        android:importantForAutofill="no" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_send_email"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_button_rounded_red"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="Kirim Tautan Verifikasi"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Opsi Via WhatsApp (Green Border when selected) -->
            <LinearLayout
                android:id="@+id/cardSms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/se2e8f0sw1cr14bf8fafc"
                android:orientation="vertical"
                android:padding="20dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_icon_rounded_light_green" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="-36dp"
                        android:src="@drawable/ic_telp"
                        app:tint="#10B981"
                        android:contentDescription="@string/label_phone" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="26dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:text="WhatsApp Support"
                            android:textColor="#1E293B"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:text="Bantuan manual via admin resmi"
                            android:textColor="#94A3B8"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/container_input_sms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="MASUKKAN NOMOR HANDPHONE"
                        android:textColor="#475569"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"/>

                    <EditText
                        android:id="@+id/et_reset_phone"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/se2e8f0sw1cr14bf8fafc"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:inputType="phone"
                        android:paddingHorizontal="16dp"
                        android:textColor="#1E293B"
                        android:textSize="14sp"
                        android:hint="@string/hint_phone"
                        android:importantForAutofill="no" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_send_sms"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_button_rounded_red"
                        android:backgroundTint="#10B981"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="Hubungi Admin WhatsApp"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Halaman Login Teks Saja dengan Padding besar -->
            <LinearLayout
                android:id="@+id/btnBatal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:padding="16dp"
                android:minHeight="48dp"
                android:clickable="true"
                android:focusable="true"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="Kembali ke "
                    android:textColor="#94A3B8"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="Halaman Login"
                    android:textColor="#C0392B"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- State 2: Email Sent Success -->
        <LinearLayout
            android:id="@+id/stateSuccess"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="gone">

            <FrameLayout
                android:id="@+id/iconContainerSuccess"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp">
                <View
                    android:id="@+id/bgCircleSuccess"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_icon_rounded_light_green"
                    android:alpha="0.4"
                    android:importantForAccessibility="no" />
                <ImageView
                    android:id="@+id/ivCheckSuccess"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_check_premium"
                    app:tint="#10B981"
                    android:contentDescription="@string/desc_success" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="Email Terkirim ✓"
                android:textColor="#1E293B"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSuccessDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="Cek inbox email Anda.\nTautan reset password telah dikirim."
                android:textColor="#64748B"
                android:textSize="14sp" />

            <!-- Kotak Keterangan Spam (Rounded Rectangle) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/se2e8f0sw1cr14bf8fafc"
                android:backgroundTint="#DCFCE7"
                android:padding="20dp"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="Jika tidak ada dalam 5 menit,\ncek folder Spam atau coba kirim ulang"
                    android:textColor="#166534"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp"/>
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnOpenEmail"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_button_rounded_red"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="Buka Aplikasi Email"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnResend"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/se2e8f0sw1cr14bf8fafc"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="Kirim Ulang"
                    android:textAllCaps="false"
                    android:textColor="#64748B"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:elevation="0dp"
                    android:stateListAnimator="@null" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnBackToLogin"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/se2e8f0sw1cr14bf8fafc"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="Kembali Login"
                    android:textAllCaps="false"
                    android:textColor="#C0392B"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:elevation="0dp"
                    android:stateListAnimator="@null" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
