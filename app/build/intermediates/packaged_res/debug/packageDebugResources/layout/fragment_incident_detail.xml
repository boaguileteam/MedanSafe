<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/bottom_sheet_persistent_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_bottom_sheet"
    android:elevation="16dp"
    android:fillViewport="true"
    android:overScrollMode="never">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingBottom="40dp">

        <!-- Drag Handle (Garis kecil di atas sheet) -->
        <View
            android:id="@+id/drag_handle"
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_marginTop="12dp"
            android:background="#E2E8F0"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Bagian Atas: Profil Pelapor & Tanggal -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_reporter_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/drag_handle">

            <androidx.cardview.widget.CardView
                android:id="@+id/cv_reporter_avatar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardBackgroundColor="#F1F5F9"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/ivReporterAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_person"
                    android:contentDescription="@string/desc_profile" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tv_reporter_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="Nama Pelapor"
                android:textColor="#1E293B"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@+id/tv_reporter_title_badge"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toEndOf="@id/cv_reporter_avatar"
                app:layout_constraintTop_toTopOf="@id/cv_reporter_avatar"
                app:layout_constraintWidth_default="wrap" />

            <TextView
                android:id="@+id/tv_reporter_title_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_pill"
                android:backgroundTint="#F1F5F9"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textColor="#64748B"
                android:textSize="9sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/tv_reporter_name"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/tv_reporter_name"
                app:layout_constraintTop_toTopOf="@id/tv_reporter_name"
                tools:text="ANGGOTA BARU" />

            <TextView
                android:id="@+id/tv_report_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Memuat waktu..."
                android:textColor="#94A3B8"
                android:textSize="11sp"
                app:layout_constraintStart_toStartOf="@id/tv_reporter_name"
                app:layout_constraintTop_toBottomOf="@id/tv_reporter_name" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Judul / Alamat Utama -->
        <TextView
            android:id="@+id/tv_full_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="Memuat alamat..."
            android:textColor="#1E293B"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/cl_reporter_header" />

        <!-- Foto Kejadian -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cv_incident_photo"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#F8FAFC"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/tv_full_address">

            <ImageView
                android:id="@+id/iv_incident_photo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />

            <LinearLayout
                android:id="@+id/ll_no_photo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_menu_camera"
                    app:tint="#CBD5E1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Foto tidak tersedia"
                    android:textColor="#94A3B8"
                    android:textSize="12sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Status & Skor Row -->
        <LinearLayout
            android:id="@+id/ll_status_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/cv_incident_photo">

            <TextView
                android:id="@+id/tv_detail_type"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_pill"
                android:backgroundTint="#FEE2E2"
                android:gravity="center"
                android:textColor="#C0392B"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="KATEGORI" />

            <LinearLayout
                android:id="@+id/ll_score_container"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_pill"
                android:backgroundTint="#FEE2E2"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_incident_score_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SKOR: "
                    android:textColor="#C0392B"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_incident_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/100"
                    android:textColor="#C0392B"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Deskripsi Laporan -->
        <TextView
            android:id="@+id/tv_label_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:letterSpacing="0.05"
            android:text="KETERANGAN LAPORAN"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ll_status_row" />

        <TextView
            android:id="@+id/tv_detail_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="5dp"
            android:text="..."
            android:textColor="#475569"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tv_label_desc" />

        <!-- Tombol Aksi di Bagian Bawah -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tv_detail_desc"
            app:layout_constraintBottom_toBottomOf="parent">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_upvote_bottom"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_rounded_16"
                android:backgroundTint="#F1F5F9"
                android:stateListAnimator="@null"
                android:text="Upvote (0)"
                android:textAllCaps="false"
                android:textColor="#1E293B"
                android:textSize="14sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_report_here"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_rounded_16"
                android:backgroundTint="#C0392B"
                android:stateListAnimator="@null"
                android:text="Lapor di Area Ini"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
