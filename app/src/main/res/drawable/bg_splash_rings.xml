<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Ring - Subtle Red -->
    <item>
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#33C0392B" />
            <size android:width="280dp" android:height="280dp" />
        </shape>
    </item>
    <!-- Middle Ring - Stronger Red -->
    <item android:top="40dp" android:bottom="40dp" android:left="40dp" android:right="40dp">
        <shape android:shape="oval">
            <stroke android:width="1.5dp" android:color="#66C0392B" />
        </shape>
    </item>
    <!-- Inner Glow (Cahaya Tengah) - Opacity diturunkan -->
    <item android:top="60dp" android:bottom="60dp" android:left="60dp" android:right="60dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="120dp"
                android:startColor="#26C0392B"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>
</layer-list>