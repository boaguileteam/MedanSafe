<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Header Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_header"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="#0A0E1A"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Decorative Circle Top Right -->
        <View
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:layout_marginTop="-45dp"
            android:layout_marginEnd="-45dp"
            android:background="@drawable/cr60bc0392b12"
            android:alpha="0.9"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Back Navigation Row with Breadcrumb -->
        <LinearLayout
            android:id="@+id/btn_back_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:minHeight="48dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.cardview.widget.CardView
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#1E293B"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp"
                    android:src="@drawable/ic_back1"
                    app:tint="#FFFFFF"
                    android:contentDescription="Kembali" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="Profil"
                android:textColor="#80FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="Kontak Darurat"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_back_container" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="Maks. 3 kontak untuk SOS"
            android:textColor="#4B5563"
            android:textSize="13sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_title" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Content Section -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#FFFFFF"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cl_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#FEF3C7"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_search"
                        app:tint="#D97706"
                        android:contentDescription="Info" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="Pastikan nomor aktif untuk SOS."
                        android:textColor="#92400E"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tv_count_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="KONTAK TERSIMPAN (0/3)"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold" />

            <!-- Dynamic Contact List Container -->
            <LinearLayout
                android:id="@+id/ll_contact_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Add Button (Dashed) -->
            <FrameLayout
                android:id="@+id/btn_add_contact_container"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_btn_add_dashed"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="+ Tambah Kontak Baru"
                    android:textColor="#C0392B"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- Test Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_test_sms"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"
                android:backgroundTint="#DCFCE7"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="Test Kirim Pesan Uji"
                android:textColor="#059669"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="14dp"
                app:elevation="0dp"
                app:icon="@drawable/ic_nav_history"
                app:iconGravity="textStart"
                app:iconSize="18dp"
                app:iconTint="#059669" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>