<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A">

    <!-- Decorative Circle top right -->
    <View
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginTop="-45dp"
        android:layout_marginEnd="-45dp"
        android:alpha="0.12"
        android:background="@drawable/bg_google_circle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Header / Back Section -->
    <LinearLayout
        android:id="@+id/btn_back_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Kembali ke Login"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#1E293B"
            app:cardElevation="0dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:src="@drawable/ic_back1"
                app:tint="#FFFFFF"
                android:contentDescription="@null" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="Login"
            android:textColor="#88FFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/plus_jakarta_sans"
        android:text="Lupa\nPassword?"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:lineSpacingExtra="-2dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_back_container" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="6dp"
        android:fontFamily="@font/plus_jakarta_sans"
        android:text="Pilih metode verifikasi untuk reset kata sandi"
        android:textColor="#88FFFFFF"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <!-- Main Content Area -->
    <View
        android:id="@+id/bg_white_form"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:background="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="@id/bg_white_form">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- State 1: Input -->
            <LinearLayout
                android:id="@+id/stateInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Email Card -->
                <LinearLayout
                    android:id="@+id/cardEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/sc0392bsw1cr14"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Metode Email">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <View android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_icon_rounded_light_red" />
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_marginStart="-36dp" android:src="@drawable/ic_email" app:tint="#C0392B" android:contentDescription="@null" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="26dp" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/plus_jakarta_sans" android:text="Email Terdaftar" android:textColor="#1E293B" android:textSize="16sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/plus_jakarta_sans" android:text="Terima tautan verifikasi otomatis" android:textColor="#94A3B8" android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/container_input_email" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:fontFamily="@font/plus_jakarta_sans" android:text="MASUKKAN ALAMAT EMAIL" android:textColor="#475569" android:textSize="11sp" android:textStyle="bold" />
                        <EditText android:id="@+id/et_reset_email" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/se2e8f0sw1cr14bf8fafc" android:fontFamily="@font/plus_jakarta_sans" android:inputType="textEmailAddress" android:paddingHorizontal="16dp" android:textColor="#1E293B" android:textSize="14sp" android:hint="email@example.com" />
                        <androidx.appcompat.widget.AppCompatButton android:id="@+id/btn_send_email" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginTop="16dp" android:background="@drawable/bg_button_rounded_red" android:fontFamily="@font/plus_jakarta_sans" android:text="Kirim Tautan Verifikasi" android:textAllCaps="false" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- WhatsApp Card -->
                <LinearLayout
                    android:id="@+id/cardSms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/se2e8f0sw1cr14bf8fafc"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Metode WhatsApp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
                        <View android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_icon_rounded_light_green" />
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_marginStart="-36dp" android:src="@drawable/ic_telp" app:tint="#10B981" android:contentDescription="@null" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="26dp" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/plus_jakarta_sans" android:text="WhatsApp Support" android:textColor="#1E293B" android:textSize="16sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/plus_jakarta_sans" android:text="Bantuan manual via admin resmi" android:textColor="#94A3B8" android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout android:id="@+id/container_input_sms" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:orientation="vertical" android:visibility="gone">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:fontFamily="@font/plus_jakarta_sans" android:text="MASUKKAN NOMOR HANDPHONE" android:textColor="#475569" android:textSize="11sp" android:textStyle="bold" />
                        <EditText android:id="@+id/et_reset_phone" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/se2e8f0sw1cr14bf8fafc" android:fontFamily="@font/plus_jakarta_sans" android:inputType="phone" android:paddingHorizontal="16dp" android:textColor="#1E293B" android:textSize="14sp" android:hint="+628xxxxxxxxxx" />
                        <androidx.appcompat.widget.AppCompatButton android:id="@+id/btn_send_sms" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginTop="16dp" android:background="@drawable/bg_button_rounded_red" android:backgroundTint="#10B981" android:fontFamily="@font/plus_jakarta_sans" android:text="Hubungi Admin WhatsApp" android:textAllCaps="false" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnBackToLogin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="16dp"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/plus_jakarta_sans" android:text="Kembali ke " android:textColor="#94A3B8" android:textSize="14sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/plus_jakarta_sans" android:text="Halaman Login" android:textColor="#C0392B" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- State 2: Success -->
            <LinearLayout
                android:id="@+id/stateSuccess"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center_horizontal"
                android:visibility="gone">

                <FrameLayout android:id="@+id/iconContainerSuccess" android:layout_width="100dp" android:layout_height="100dp" android:layout_marginTop="32dp" android:layout_marginBottom="24dp">
                    <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_icon_rounded_light_green" android:alpha="0.4" />
                    <ImageView android:id="@+id/ivCheckSuccess" android:layout_width="44dp" android:layout_height="44dp" android:layout_gravity="center" android:src="@drawable/ic_check_premium" app:tint="#10B981" android:contentDescription="Berhasil" />
                </FrameLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/plus_jakarta_sans" android:text="Email Terkirim ✓" android:textColor="#1E293B" android:textSize="22sp" android:textStyle="bold" />
                <TextView android:id="@+id/tvSuccessDesc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:gravity="center" android:fontFamily="@font/plus_jakarta_sans" android:text="Cek inbox email Anda.\nTautan reset password telah dikirim." android:textColor="#64748B" android:textSize="14sp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:background="#DCFCE7" android:padding="20dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/plus_jakarta_sans" android:text="Jika tidak ada dalam 5 menit,\ncek folder Spam atau coba kirim ulang" android:textColor="#166534" android:textSize="13sp" android:gravity="center" />
                </LinearLayout>

                <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnOpenEmail" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="32dp" android:background="@drawable/bg_button_rounded_red" android:fontFamily="@font/plus_jakarta_sans" android:text="Buka Aplikasi Email" android:textAllCaps="false" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:orientation="horizontal">
                    <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnResend" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:layout_marginEnd="8dp" android:background="#F1F5F9" android:fontFamily="@font/plus_jakarta_sans" android:text="Kirim Ulang" android:textAllCaps="false" android:textColor="#64748B" android:textSize="14sp" android:textStyle="bold" android:stateListAnimator="@null" />
                    <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnFinalBack" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:layout_marginStart="8dp" android:background="#F1F5F9" android:fontFamily="@font/plus_jakarta_sans" android:text="Kembali Login" android:textAllCaps="false" android:textColor="#C0392B" android:textSize="14sp" android:textStyle="bold" android:stateListAnimator="@null" />
                </LinearLayout>
            </LinearLayout>

        </FrameLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>