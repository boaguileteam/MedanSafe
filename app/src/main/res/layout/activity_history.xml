<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F5F9">

    <!-- Header Area -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_header_history"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="#0A0E1A"
        app:layout_constraintTop_toTopOf="parent">

        <!-- DECORATIVE CIRCLE -->
        <View
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:layout_marginTop="-45dp"
            android:layout_marginEnd="-45dp"
            android:background="@drawable/cr60bc0392b12"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Back Navigation Row with Breadcrumb -->
        <LinearLayout
            android:id="@+id/btn_back_history_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:minHeight="48dp"
            android:contentDescription="@string/label_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.cardview.widget.CardView
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#1E293B"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/btn_back_history"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp"
                    android:src="@drawable/ic_back1"
                    app:tint="#FFFFFF"
                    android:contentDescription="@null" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="Profil"
                android:textColor="#80FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_title_history"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="Riwayat Laporan"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_back_history_container" />

        <TextView
            android:id="@+id/tv_stats_history"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="0 laporan • 0 terverifikasi"
            android:textColor="#94A3B8"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_title_history" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Filter Tabs -->
    <HorizontalScrollView
        android:id="@+id/hsv_filters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:scrollbars="none"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/cl_header_history">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_filter_all"
                android:layout_width="wrap_content"
                android:layout_height="35dp"
                android:background="@drawable/bg_pill"
                android:backgroundTint="#C0392B"
                android:text="Semua"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="20dp"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:textSize="12sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_filter_verified"
                android:layout_width="wrap_content"
                android:layout_height="35dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_pill"
                android:backgroundTint="#FFFFFF"
                android:text="Terverifikasi"
                android:textAllCaps="false"
                android:textColor="#64748B"
                android:paddingHorizontal="20dp"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:textSize="12sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_filter_pending"
                android:layout_width="wrap_content"
                android:layout_height="35dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_pill"
                android:backgroundTint="#FFFFFF"
                android:text="Menunggu"
                android:textAllCaps="false"
                android:textColor="#64748B"
                android:paddingHorizontal="20dp"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:textSize="12sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_filter_rejected"
                android:layout_width="wrap_content"
                android:layout_height="35dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_pill"
                android:backgroundTint="#FFFFFF"
                android:text="Ditolak"
                android:textAllCaps="false"
                android:textColor="#64748B"
                android:paddingHorizontal="20dp"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:textSize="12sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_history"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:paddingBottom="24dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hsv_filters"
        tools:listitem="@layout/item_incident" />

    <!-- Empty State View -->
    <LinearLayout
        android:id="@+id/ll_empty_history"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hsv_filters">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:alpha="0.4"
            android:src="@drawable/ic_nav_history"
            android:contentDescription="@null"
            app:tint="#94A3B8" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="Belum ada laporan"
            android:textColor="#64748B"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="Laporan kamu akan muncul di sini"
            android:textColor="#94A3B8"
            android:textSize="14sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>