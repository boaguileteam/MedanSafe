<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Top Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_top_bar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/cv_back_detail"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#F1F5F9"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/btn_back_detail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackground"
                android:contentDescription="@string/desc_back_icon"
                android:padding="12dp"
                android:src="@drawable/ic_back1"
                app:tint="#334155" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tv_toolbar_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="Laporan Warga"
            android:textColor="#1E293B"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/ll_bottom_actions"
        app:layout_constraintTop_toBottomOf="@id/cl_top_bar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- Reporter Header -->
            <LinearLayout
                android:id="@+id/ll_reporter_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.cardview.widget.CardView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F1F5F9">
                    <ImageView
                        android:id="@+id/iv_detail_reporter_avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_person"
                        android:scaleType="centerCrop" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/tv_detail_reporter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:text="Nama Pelapor"
                            android:textColor="#1E293B"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <!-- NEW: Title Badge -->
                        <TextView
                            android:id="@+id/tv_detail_reporter_title_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_pill"
                            android:backgroundTint="#F1F5F9"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"
                            android:textColor="#64748B"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            tools:text="ANGGOTA BARU" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_detail_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="Waktu Kejadian"
                        android:textColor="#94A3B8"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_detail_upvotes_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pill"
                    android:backgroundTint="#F1F5F9"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="0 Upvotes"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/cv_incident_image"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/ll_reporter_header">

                <ImageView
                    android:id="@+id/iv_detail_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/bg_danger_gradient" />

                <TextView
                    android:id="@+id/tv_no_photo_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="Foto tidak tersedia"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:visibility="gone" />
            </androidx.cardview.widget.CardView>

            <!-- Status Badges: SYNCED SIZES -->
            <LinearLayout
                android:id="@+id/ll_badges"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/cv_incident_image">

                <TextView
                    android:id="@+id/tv_detail_type_badge"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_pill"
                    android:backgroundTint="#FEE2E2"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:gravity="center"
                    android:textColor="#C0392B"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="KATEGORI" />

                <LinearLayout
                    android:id="@+id/ll_score_badge_container"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_pill"
                    android:backgroundTint="#FEE2E2"
                    android:gravity="center"
                    android:paddingHorizontal="16dp">
                    <TextView
                        android:id="@+id/tv_detail_score_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SKOR: "
                        android:textColor="#C0392B"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/plus_jakarta_sans" />
                    <TextView
                        android:id="@+id/tv_detail_score_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#C0392B"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/plus_jakarta_sans"
                        tools:text="0/100" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_location_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/ll_badges">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="LOKASI KEJADIAN"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_detail_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColor="#1E293B"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="Alamat Kejadian" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_desc_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/ll_location_section">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:text="KETERANGAN LAPORAN"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_detail_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:lineSpacingExtra="5dp"
                    android:textColor="#475569"
                    android:textSize="14sp"
                    tools:text="..." />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/cv_mini_map"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/ll_desc_section">
                <org.osmdroid.views.MapView
                    android:id="@+id/mini_map"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cv_analysis_box"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="#F8FAFC"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/cv_mini_map">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="KONDISI AREA"
                        android:textColor="#94A3B8"
                        android:textSize="11sp"
                        android:letterSpacing="0.05"
                        android:textStyle="bold" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp">

                        <TextView
                            android:id="@+id/tv_label_danger"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:text="Skor Keamanan Area"
                            android:textColor="#475569"
                            android:textSize="13sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tv_area_risk_score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:textColor="#10B981"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:text="100/100" />

                        <TextView
                            android:id="@+id/tv_label_monthly"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:text="Laporan Sekitar (30 Hari)"
                            android:textColor="#475569"
                            android:textSize="13sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tv_label_danger" />

                        <TextView
                            android:id="@+id/tv_area_monthly_incidents"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:textColor="#1E293B"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tv_area_risk_score"
                            tools:text="0 Laporan" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tv_comments_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="DISKUSI WARGA"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:letterSpacing="0.05"
                android:textStyle="bold" app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cv_analysis_box" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_comments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false"
                app:layout_constraintTop_toBottomOf="@id/tv_comments_label"
                tools:itemCount="2"
                tools:listitem="@layout/item_comment" />

            <LinearLayout
                android:id="@+id/ll_comment_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_status_badge"
                android:backgroundTint="#F8FAFC"
                android:gravity="center_vertical"
                android:minHeight="52dp"
                android:paddingHorizontal="12dp"
                app:layout_constraintTop_toBottomOf="@id/rv_comments">

                <EditText
                    android:id="@+id/et_comment_detail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:autofillHints="none"
                    android:background="@null"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:hint="Tulis diskusi..."
                    android:imeOptions="actionSend"
                    android:inputType="textCapSentences"
                    android:minHeight="40dp"
                    android:textSize="13sp" />

                <ImageView
                    android:id="@+id/btn_send_comment_detail"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:contentDescription="@string/desc_send_comment"
                    android:focusable="true"
                    android:padding="8dp"
                    android:rotation="45"
                    android:src="@drawable/ic_send"
                    app:tint="#E74C3C" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/ll_bottom_actions"
        android:layout_width="match_parent"
        android:layout_height="84dp"
        android:background="#FFFFFF"
        android:elevation="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_upvote_detail"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/bg_pill"
            android:backgroundTint="#F1F5F9"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="Upvote (0)"
            android:textAllCaps="false"
            android:textColor="#1E293B"
            android:textSize="14sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_view_on_map"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:background="@drawable/bg_pill"
            android:backgroundTint="#E74C3C"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="Lihat di Peta"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
