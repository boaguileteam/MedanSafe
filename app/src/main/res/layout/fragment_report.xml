<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Header Section (Premium Minimalist - No Back/Beranda as it's a Fragment) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_header_report"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="#0A0E1A"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Decorative Circle Diagram -->
        <View
            android:id="@+id/view_decorative_circle"
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:layout_marginTop="-45dp"
            android:layout_marginEnd="-45dp"
            android:background="@drawable/cr60bc0392b12"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_report_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="45dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="Buat Laporan"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="Laporkan kejadian di sekitar Anda❤️"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_report_title" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cl_header_report">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="100dp">

            <!-- Section: Category -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="KATEGORI KEJADIAN"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:letterSpacing="0.05"
                android:textStyle="bold" />

            <GridLayout
                android:id="@+id/gl_categories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:columnCount="2">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cat_begal"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#FEE2E2"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="horizontal">
                        <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/bg_google_circle" android:backgroundTint="#C0392B" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Begal" android:textColor="#C0392B" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cat_gelap"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#E2E8F0"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="horizontal">
                        <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/bg_google_circle" android:backgroundTint="#F59E0B" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Jalan Gelap" android:textColor="#334155" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cat_kecelakaan"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#E2E8F0"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="horizontal">
                        <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/bg_google_circle" android:backgroundTint="#3B82F6" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Kecelakaan" android:textColor="#334155" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cat_lainnya"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#E2E8F0"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="horizontal">
                        <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/bg_google_circle" android:backgroundTint="#64748B" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Lainnya" android:textColor="#334155" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </GridLayout>

            <EditText
                android:id="@+id/et_custom_category"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_search_input_normal"
                android:hint="Sebutkan kategori..."
                android:paddingHorizontal="16dp"
                android:textSize="14sp"
                android:visibility="gone"
                android:autofillHints="none"
                android:inputType="text" />

            <!-- Section: Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="DESKRIPSI KEJADIAN"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_incident_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_search_input_normal"
                android:gravity="top"
                android:hint="Ceritakan detail kejadian..."
                android:inputType="textMultiLine"
                android:minHeight="100dp"
                android:padding="16dp"
                android:textSize="14sp"
                android:autofillHints="none" />

            <!-- Section: Location -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="LOKASI TERDETEKSI"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cv_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="#F8FAFC"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="#F1F5F9"
                app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:padding="14dp">
                    <View android:layout_width="14dp" android:layout_height="14dp" android:background="@drawable/bg_google_circle" android:backgroundTint="#C0392B" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:id="@+id/tv_report_addr" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Mendeteksi lokasi..." android:textColor="#1E293B" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>
                    <TextView android:id="@+id/btn_edit_report_loc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:padding="8dp" android:text="Edit" android:textColor="#C0392B" android:textSize="12sp" android:textStyle="bold" android:minHeight="48dp" android:gravity="center" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section: Photo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="FOTO KEJADIAN (OPSIONAL)"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold" />

            <FrameLayout
                android:id="@+id/btn_add_report_photo"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_dashed_border"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:id="@+id/ll_photo_placeholder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_menu_camera" app:tint="#CBD5E1" android:contentDescription="@string/desc_camera_icon" />
                    <TextView android:id="@+id/tv_photo_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Tambah Foto" android:textColor="#1E293B" android:textSize="12sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Maksimal ukuran 2MB" android:textColor="#94A3B8" android:textSize="11sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/iv_report_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:visibility="gone"
                    android:contentDescription="Preview Foto" />
            </FrameLayout>

            <!-- Section: Danger Level -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="TINGKAT BAHAYA"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/ll_danger_labels"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Rendah" android:textColor="#94A3B8" android:textSize="11sp" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Sedang" android:textColor="#94A3B8" android:textSize="11sp" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end" android:text="Tinggi" android:textColor="#94A3B8" android:textSize="11sp" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatSeekBar
                android:id="@+id/sb_danger_level"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:max="100"
                android:paddingHorizontal="0dp"
                android:progress="50"
                android:progressDrawable="@drawable/bg_danger_gradient"
                android:thumb="@drawable/bg_sb_thumb"
                android:thumbOffset="12dp"
                android:splitTrack="false" />

            <!-- Submit Section -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_send_report"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                app:backgroundTint="#C0392B"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="Kirim Laporan"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:elevation="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="Pastikan data yang Anda kirimkan benar dan dapat dipertanggungjawabkan."
                android:textColor="#94A3B8"
                android:textSize="11sp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>