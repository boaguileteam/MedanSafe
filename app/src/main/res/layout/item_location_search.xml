<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cv_location_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginBottom="6dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp">

        <!-- Icon / Emoji Container (Slimmer) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cv_location_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:cardBackgroundColor="#F1F5F9"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp">
            <TextView
                android:id="@+id/tv_location_emoji"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textSize="16sp"
                tools:text="📍" />
        </androidx.cardview.widget.CardView>

        <!-- Information Area -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_location_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="#0F172A"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="Nama Lokasi" />

            <TextView
                android:id="@+id/tv_location_address"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="#64748B"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Alamat lengkap lokasi di sini..." />
        </LinearLayout>

        <!-- Status Tag (Visible for Popular/Search) -->
        <TextView
            android:id="@+id/tv_location_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_pill"
            android:backgroundTint="#DCFCE7"
            android:fontFamily="@font/plus_jakarta_sans"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="AMAN"
            android:textColor="#16A34A"
            android:textSize="8sp"
            android:textStyle="bold"
            tools:ignore="SmallSp" />

        <!-- Favorite Toggle (Star) -->
        <ImageView
            android:id="@+id/btn_favorite_star"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:padding="4dp"
            android:src="@drawable/ic_star"
            android:visibility="gone"
            tools:visibility="visible" />

        <!-- Delete Button (X for history) -->
        <ImageView
            android:id="@+id/btn_delete_item"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:padding="6dp"
            android:src="@drawable/ic_close"
            android:visibility="gone"
            app:tint="#CBD5E1"
            tools:visibility="visible" />

    </LinearLayout>
</androidx.cardview.widget.CardView>