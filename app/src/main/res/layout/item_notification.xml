<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cv_notification"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_notif_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/cv_icon_container"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:id="@+id/view_icon_bg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#F1F5F9" />

            <ImageView
                android:id="@+id/iv_notif_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_nav_report"
                app:tint="#3B82F6" />
        </androidx.cardview.widget.CardView>

        <View
            android:id="@+id/view_unread_dot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_circle_red"
            app:layout_constraintTop_toTopOf="@id/cv_icon_container"
            app:layout_constraintEnd_toEndOf="@id/cv_icon_container"
            android:layout_marginTop="-2dp"
            android:layout_marginEnd="-2dp"
            android:translationZ="2dp" />

        <TextView
            android:id="@+id/tv_notif_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="2 menit lalu" />

        <TextView
            android:id="@+id/tv_notif_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:fontFamily="@font/plus_jakarta_sans_bold"
            android:maxLines="1"
            android:textColor="#1E293B"
            android:textSize="15sp"
            app:layout_constraintEnd_toStartOf="@id/tv_notif_time"
            app:layout_constraintStart_toEndOf="@id/cv_icon_container"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Laporan Terverifikasi" />

        <TextView
            android:id="@+id/tv_notif_content"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:fontFamily="@font/plus_jakarta_sans"
            android:maxLines="2"
            android:textColor="#64748B"
            android:textSize="13sp"
            android:lineSpacingExtra="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tv_notif_title"
            app:layout_constraintTop_toBottomOf="@id/tv_notif_title"
            tools:text="Laporan kamu di Jl. Gajah Mada telah diverifikasi oleh admin." />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
